# ==========================================
# Konfigurasi Server Express
# ==========================================
PORT=5000
NODE_ENV=development

# ==========================================
# Konfigurasi SATUSEHAT
# ==========================================
# Base URL API (Gunakan versi staging/sandbox untuk pengembangan)
SATUSEHAT_BASE_URL=https://api-satusehat-stg.dto.kemkes.go.id

# Kredensial Fasyankes (Dapatkan dari Portal Developer SATUSEHAT)
SATUSEHAT_ORG_ID=your_organization_id_here
SATUSEHAT_CLIENT_ID=your_client_id_here
SATUSEHAT_CLIENT_SECRET=your_client_secret_here

# ==========================================
# Autentikasi aplikasi (login admin sementara)
# ==========================================
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=admin123
AUTH_SESSION_TTL_HOURS=24
